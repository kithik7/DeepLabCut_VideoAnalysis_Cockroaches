# =============================================================================
# CALCULATE PREFERENCE INDICES FOR EACH DATASET
# =============================================================================

def calculate_preference_indices(df):
    \"\"\"Calculate all preference indices for a dataset\"\"\"
    
    # Create odor pair type
    df['odor_pair_type'] = df.apply(
        lambda row: 'Iso vs Feces' if ('Iso' in [row['left_shelter_odor'], row['right_shelter_odor']] and 
                                      'Feces' in [row['left_shelter_odor'], row['right_shelter_odor']]) else
                   'Iso vs Nothing' if ('Iso' in [row['left_shelter_odor'], row['right_shelter_odor']] and 
                                       'Nothing' in [row['left_shelter_odor'], row['right_shelter_odor']]) else
                   'Feces vs Nothing' if ('Feces' in [row['left_shelter_odor'], row['right_shelter_odor']] and 
                                         'Nothing' in [row['left_shelter_odor'], row['right_shelter_odor']]) else 'Other', axis=1)

    # 1. TIME-BASED PREFERENCE INDEX (-1 to +1)
    def calculate_time_preference(row):
        total_shelter_time = row['time_left_shelter'] + row['time_right_shelter']
        if total_shelter_time > 0:
            return (row['time_left_shelter'] - row['time_right_shelter']) / total_shelter_time
        else:
            return 0

    df['pref_index_time'] = df.apply(calculate_time_preference, axis=1)

    # 2. ODOR PREFERENCE INDEX (For odor vs nothing comparisons)
    def calculate_odor_preference(row):
        if row['odor_pair_type'] in ['Iso vs Nothing', 'Feces vs Nothing']:
            if row['left_shelter_odor'] in ['Iso', 'Feces']:
                odor_time = row['time_left_shelter']
                nothing_time = row['time_right_shelter']
            else:
                odor_time = row['time_right_shelter']
                nothing_time = row['time_left_shelter']
            
            total_time = odor_time + nothing_time
            if total_time > 0:
                return (odor_time - nothing_time) / total_time
            else:
                return 0
        else:
            return np.nan

    df['pref_index_odor'] = df.apply(calculate_odor_preference, axis=1)

    # 3. RELATIVE PREFERENCE STRENGTH (0 to 1)
    df['pref_strength'] = df['pref_index_time'].abs()

    # 4. SHELTER VS OPEN PREFERENCE (-1 to +1)
    def calculate_shelter_preference(row):
        total_time = row['time_left_shelter'] + row['time_right_shelter'] + row['time_open_area']
        if total_time > 0:
            shelter_time = row['time_left_shelter'] + row['time_right_shelter']
            return (shelter_time - row['time_open_area']) / total_time
        else:
            return 0

    df['pref_index_shelter_vs_open'] = df.apply(calculate_shelter_preference, axis=1)

    # 5. ODOR-SPECIFIC PREFERENCE INDICES
    def calculate_iso_preference(row):
        if 'Iso' in [row['left_shelter_odor'], row['right_shelter_odor']]:
            if row['left_shelter_odor'] == 'Iso':
                iso_time = row['time_left_shelter']
                other_time = row['time_right_shelter']
            else:
                iso_time = row['time_right_shelter']
                other_time = row['time_left_shelter']
            
            total_time = iso_time + other_time
            if total_time > 0:
                return (iso_time - other_time) / total_time
        return np.nan

    def calculate_feces_preference(row):
        if 'Feces' in [row['left_shelter_odor'], row['right_shelter_odor']]:
            if row['left_shelter_odor'] == 'Feces':
                feces_time = row['time_left_shelter']
                other_time = row['time_right_shelter']
            else:
                feces_time = row['time_right_shelter']
                other_time = row['time_left_shelter']
            
            total_time = feces_time + other_time
            if total_time > 0:
                return (feces_time - other_time) / total_time
        return np.nan

    df['pref_index_iso'] = df.apply(calculate_iso_preference, axis=1)
    df['pref_index_feces'] = df.apply(calculate_feces_preference, axis=1)
    
    return df

# Calculate indices for each dataset
