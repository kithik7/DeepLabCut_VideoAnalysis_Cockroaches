python -c "
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from scipy import stats
import warnings
warnings.filterwarnings('ignore')


# Set muted color palette with hex codes
muted_palette = ['#4C72B0', '#DD8452', '#55A868', '#C44E52', '#8172B3', '#937860', '#DA8BC3', '#8C8C8C']
sns.set_palette(muted_palette)
plt.style.use('seaborn-v0_8-whitegrid')



datasets = {}

# Load all frames group data
try:
    all_frames_df = pd.read_csv('comprehensive_group_analysis_all_frames.csv')
    all_frames_df = all_frames_df[all_frames_df['error'].isna()].copy()
    all_frames_df['dataset'] = 'All Frames'
    datasets['All Frames'] = all_frames_df
except Exception as e:
    print(f' Error loading all frames data: {e}')

# Load tracking efficiency group data
try:
    tracking_df = pd.read_csv('comprehensive_analysis_tracking_efficiency.csv')
    tracking_df = tracking_df[tracking_df['error'].isna()].copy()
    tracking_df['dataset'] = 'Tracking Filtered'
    datasets['Tracking Filtered'] = tracking_df
except Exception as e:
    print(f'Error loading tracking data: {e}')

if not datasets:
    print(' No datasets loaded successfully!')
    exit()

#calculate pref indices for each dataset 

def calculate_preference_indices(df):
    \"\"\"Calculate all preference indices for a dataset\"\"\"
    
    # Create odor pair type
    df['odor_pair_type'] = df.apply(
        lambda row: 'Iso vs Feces' if ('Iso' in [row['left_shelter_odor'], row['right_shelter_odor']] and 
                                      'Feces' in [row['left_shelter_odor'], row['right_shelter_odor']]) else
                   'Iso vs Nothing' if ('Iso' in [row['left_shelter_odor'], row['right_shelter_odor']] and 
                                       'Nothing' in [row['left_shelter_odor'], row['right_shelter_odor']]) else
                   'Feces vs Nothing' if ('Feces' in [row['left_shelter_odor'], row['right_shelter_odor']] and 
                                         'Nothing' in [row['left_shelter_odor'], row['right_shelter_odor']]) else 'Other', axis=1)

    # 1.time based pref index (-1 to +1)
    def calculate_time_preference(row):
        total_shelter_time = row['time_left_shelter'] + row['time_right_shelter']
        if total_shelter_time > 0:
            return (row['time_left_shelter'] - row['time_right_shelter']) / total_shelter_time
        else:
            return 0

    df['pref_index_time'] = df.apply(calculate_time_preference, axis=1)

    # 2. odor pref index (For odor vs nothing comparisons)
    def calculate_odor_preference(row):
        if row['odor_pair_type'] in ['Iso vs Nothing', 'Feces vs Nothing']:
            if row['left_shelter_odor'] in ['Iso', 'Feces']:
                odor_time = row['time_left_shelter']
                nothing_time = row['time_right_shelter']
            else:
                odor_time = row['time_right_shelter']
                nothing_time = row['time_left_shelter']
            
            total_time = odor_time + nothing_time
            if total_time > 0:
                return (odor_time - nothing_time) / total_time
            else:
                return 0
        else:
            return np.nan

    df['pref_index_odor'] = df.apply(calculate_odor_preference, axis=1)

    # 3. Relative pref strength (0 to 1)
    df['pref_strength'] = df['pref_index_time'].abs()

    # 4. shelter vs open preference (-1 to +1)
    def calculate_shelter_preference(row):
        total_time = row['time_left_shelter'] + row['time_right_shelter'] + row['time_open_area']
        if total_time > 0:
            shelter_time = row['time_left_shelter'] + row['time_right_shelter']
            return (shelter_time - row['time_open_area']) / total_time
        else:
            return 0

    df['pref_index_shelter_vs_open'] = df.apply(calculate_shelter_preference, axis=1)

    # 5. odor specific preference indices
    def calculate_iso_preference(row):
        if 'Iso' in [row['left_shelter_odor'], row['right_shelter_odor']]:
            if row['left_shelter_odor'] == 'Iso':
                iso_time = row['time_left_shelter']
                other_time = row['time_right_shelter']
            else:
                iso_time = row['time_right_shelter']
                other_time = row['time_left_shelter']
            
            total_time = iso_time + other_time
            if total_time > 0:
                return (iso_time - other_time) / total_time
        return np.nan

    def calculate_feces_preference(row):
        if 'Feces' in [row['left_shelter_odor'], row['right_shelter_odor']]:
            if row['left_shelter_odor'] == 'Feces':
                feces_time = row['time_left_shelter']
                other_time = row['time_right_shelter']
            else:
                feces_time = row['time_right_shelter']
                other_time = row['time_left_shelter']
            
            total_time = feces_time + other_time
            if total_time > 0:
                return (feces_time - other_time) / total_time
        return np.nan

    df['pref_index_iso'] = df.apply(calculate_iso_preference, axis=1)
    df['pref_index_feces'] = df.apply(calculate_feces_preference, axis=1)
    
    return df

# Calculate indices for each dataset
for name, df in datasets.items():
    datasets[name] = calculate_preference_indices(df)
    print(f'Calculated indices for {name}: {len(df)} animals')


#create separate pref indices csvs 

# Common columns for preference indices
pref_columns = [
    'video', 'date', 'batch', 'experiment_type', 'odor_pair_type',
    'left_shelter_odor', 'right_shelter_odor', 'animal_id',
    'preferred_zone', 'preferred_odor',
    'time_left_shelter', 'time_right_shelter', 'time_open_area',
    'percent_left', 'percent_right', 'percent_open',
    'pref_index_time', 'pref_index_odor', 'pref_strength', 
    'pref_index_shelter_vs_open', 'pref_index_iso', 'pref_index_feces',
    'dataset'
]

# Add tracking-specific columns if available
tracking_cols = ['tracking_efficiency', 'avg_likelihood', 'tracking_quality', 
                'valid_frames', 'total_frames', 'avg_segment_length']

# Create preference indices datasets
for name, df in datasets.items():
    available_cols = [col for col in pref_columns if col in df.columns]
    
    # Add tracking columns if this is the tracking dataset
    if name == 'Tracking Filtered':
        available_tracking_cols = [col for col in tracking_cols if col in df.columns]
        available_cols.extend(available_tracking_cols)
    
    pref_df = df[available_cols].copy()
    
    # Save to CSV
    output_file = f'preference_index_{name.lower().replace(\" \", \"_\")}_group.csv'
    pref_df.to_csv(output_file, index=False)
    print(f'Saved {output_file}: {len(pref_df)} records')


# Combine both datasets for comparison

combined_dfs = []
for name, df in datasets.items():
    available_cols = [col for col in pref_columns if col in df.columns]
    combined_dfs.append(df[available_cols].copy())

combined_df = pd.concat(combined_dfs, ignore_index=True)

# Save combined dataset
combined_df.to_csv('preference_index_combined_group.csv', index=False)



print(f'\\n Job Done')

